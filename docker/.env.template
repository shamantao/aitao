# =============================================================================
# AI Tao - Configuration Environnement
# =============================================================================
# Copiez ce fichier vers .env et ajustez les valeurs si nécessaire.
# Le script install-aitao.sh le fait automatiquement.
# =============================================================================

# --- Ports des services ---
# Modifiez uniquement si les ports par défaut sont déjà utilisés sur votre Mac
API_PORT=8200
OLLAMA_PORT=11434
MEILISEARCH_PORT=7700
WEBUI_PORT=3000

# --- Meilisearch ---
# Clé de sécurité (générée automatiquement à l'installation)
# Laissez vide pour désactiver l'authentification (dev uniquement)
MEILISEARCH_MASTER_KEY=

# --- Répertoires de données ---
# Par défaut, tout est stocké dans ~/.aitao/
# Décommentez pour personnaliser les chemins
# AITAO_CONFIG_DIR=~/.aitao/config
# AITAO_DATA_DIR=~/.aitao/data
# AITAO_LOGS_DIR=~/.aitao/logs

# --- Logs ---
# Niveau de log: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
