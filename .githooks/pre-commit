#!/bin/bash
# Pre-commit hook for AItao
# 
# This hook prevents committing files that contain 'pip install' 
# without the 'uv' prefix, enforcing the uv-first policy.
#
# To install: git config core.hooksPath .githooks

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo "🔍 AItao pre-commit check..."

# Check for 'pip install' WITHOUT 'uv' prefix in staged files
# We use grep -P for perl regex to match "pip install" not preceded by "uv "
# Exclude documentation files and this hook itself
STAGED_FILES=$(git diff --cached --name-only | grep -E "\.(py|sh|bash)$" | grep -v ".githooks/")

if [ -n "$STAGED_FILES" ]; then
    OFFENDING=""
    for file in $STAGED_FILES; do
        # Match lines with "pip install" but NOT "uv pip install"
        if grep -E "^[^#]*pip install" "$file" 2>/dev/null | grep -v "uv pip install" | grep -q "pip install"; then
            OFFENDING="$OFFENDING $file"
        fi
    done
    
    if [ -n "$OFFENDING" ]; then
        echo -e "${RED}❌ ERROR: Found 'pip install' without 'uv' prefix!${NC}"
        echo ""
        echo "The following files use 'pip install' instead of 'uv pip install':"
        for file in $OFFENDING; do
            echo -e "  ${YELLOW}→ $file${NC}"
            grep -n "pip install" "$file" 2>/dev/null | grep -v "uv pip" | head -3 | while read line; do
                echo "      $line"
            done
        done
        echo ""
        echo -e "${YELLOW}AItao uses 'uv' for dependency management (PRD requirement).${NC}"
        echo "Please replace 'pip install' with 'uv pip install'."
        echo ""
        echo "To bypass (not recommended): git commit --no-verify"
        exit 1
    fi
fi

echo -e "${GREEN}✓ No 'pip install' issues found${NC}"
exit 0
