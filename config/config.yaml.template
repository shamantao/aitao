# =============================================================================
# AItao V2 Configuration Template
# =============================================================================
# 
# Copy this file to config.yaml and customize for your environment.
# 
#   cp config.yaml.template config.yaml
#
# Environment variables:
#   Use ${VAR_NAME} syntax to reference environment variables
#   Example: ${HOME}/aitao will expand to /Users/username/aitao
#
# =============================================================================

# -----------------------------------------------------------------------------
# Paths Configuration
# -----------------------------------------------------------------------------
# Define where AItao stores data, logs, and temporary files
paths:
  # Root directory for all AItao data
  # Default: ${HOME}/.aitao/data
  storage_root: "${HOME}/.aitao/data"
  
  # Logs directory
  logs_dir: "${storage_root}/logs"
  
  # Queue directory for pending document processing
  queue_dir: "${storage_root}/queue"
  
  # Cache directory for OCR and translation results
  cache_dir: "${storage_root}/cache"
  
  # Corrections directory for manual OCR/translation fixes
  corrections_dir: "${storage_root}/corrections"
  
  # LanceDB vector database directory
  vector_db_dir: "${storage_root}/lancedb"

# -----------------------------------------------------------------------------
# Worker Configuration
# -----------------------------------------------------------------------------
# Configure background worker behavior
worker:
  # Seconds between queue polls (lower = faster processing, higher CPU)
  # Default: 5 seconds
  poll_interval: 5
  
  # Maximum CPU usage before pausing processing
  cpu_threshold: 80.0
  
  # Seconds before a stuck task is reset to pending
  stuck_task_timeout: 600

# -----------------------------------------------------------------------------
# Indexing Configuration
# -----------------------------------------------------------------------------
# Configure document scanning and indexing behavior
indexing:
  # Enable automatic periodic indexing
  enabled: true
  
  # Interval between automatic scans (in minutes)
  interval_minutes: 60
  
  # Paths to include in indexing (absolute paths)
  # Add all directories you want to make searchable
  include_paths:
    - "${HOME}/Documents/"
    # Add more paths here:
    # - "${HOME}/Downloads/"
    # - "/Volumes/ExternalDrive/"
  
  # Directories to exclude from indexing
  exclude_dirs:
    - "__pycache__"
    - ".git"
    - ".venv"
    - "venv"
    - "env"
    - ".env"
    - "node_modules"
    - ".ds_store"
    - "dist"
    - "build"
    - "target"
    - "site-packages"
    - ".idea"
    - ".vscode"
  
  # Files to exclude from indexing
  exclude_files:
    - ".DS_Store"
    - "package-lock.json"
    - "yarn.lock"
    - "Thumbs.db"
  
  # File extensions to exclude
  exclude_extensions:
    - ".lock"
    - ".log"
    - ".tmp"
    - ".swp"
    - ".cache"

# -----------------------------------------------------------------------------
# OCR Configuration
# -----------------------------------------------------------------------------
# Configure optical character recognition for images and PDFs
ocr:
  # OCR provider selection
  # Options: "auto" (smart routing), "native" (fast), "qwen-vl" (best for tables)
  provider: "auto"
  
  # Languages to recognize (ISO 639-1 codes)
  languages:
    - "en"
    - "fr"
    # - "zh"  # Add for Chinese support
  
  # Confidence threshold for OCR results (0.0 - 1.0)
  confidence_threshold: 0.7
  
  # Smart router configuration (when provider = "auto")
  router:
    # Table detection thresholds
    table_area_min: 0.05        # Min 5% of image should be table grid
    min_intersections: 2         # Min 2 grid intersections detected
    min_line_density: 0.0002    # Min line coverage density
  
  # Native OCR settings (macOS: Vision API, Linux: Tesseract)
  native:
    # Timeout in seconds for OCR operations
    timeout: 60
  
  # Qwen-VL specific settings (for complex documents with tables)
  qwen_vl:
    # Path to Qwen2.5-VL GGUF model file (for local inference)
    model_path: "${HOME}/.aitao/models/qwen2-vl-7b/Qwen2.5-VL-7B-Instruct-Q4_K_M.gguf"
    # GPU layers to offload (0 = CPU only, -1 = auto)
    n_gpu_layers: -1
    context_size: 4096
    max_tokens: 2048

# -----------------------------------------------------------------------------
# Translation Configuration
# -----------------------------------------------------------------------------
# Configure automatic translation
translation:
  # Translation provider: "mbart50", "nllb", "ollama"
  provider: "mbart50"
  
  # Default source language
  source_lang: "en"
  
  # Default target language
  target_lang: "fr"
  
  # Enable confidence scoring
  score_translations: true
  
  # Minimum confidence score (0.0 - 1.0)
  min_confidence: 0.6
  
  # mBART50 specific settings
  mbart50:
    model_name: "facebook/mbart-large-50-many-to-many-mmt"
    use_gpu: false
    batch_size: 8
  
  # NLLB specific settings (alternative)
  nllb:
    model_name: "facebook/nllb-200-distilled-600M"
    use_gpu: false
    batch_size: 8

# -----------------------------------------------------------------------------
# Search Configuration
# -----------------------------------------------------------------------------
# Configure hybrid search (Meilisearch + LanceDB)
search:
  # Meilisearch configuration (keyword/fuzzy search)
  meilisearch:
    url: "http://localhost:7700"
    api_key: ""
    index_name: "aitao_documents"
    searchable_attributes:
      - "title"
      - "content"
      - "category"
      - "tags"
    displayed_attributes:
      - "id"
      - "title"
      - "file_path"
      - "category"
      - "language"
      - "created_at"
      - "updated_at"
    filterable_attributes:
      - "category"
      - "language"
      - "created_at"
      - "file_type"
  
  # LanceDB configuration (semantic/vector search)
  lancedb:
    # Embedding model: "BAAI/bge-m3" (multilingual, recommended)
    embedding_model: "BAAI/bge-m3"
    table_name: "aitao_embeddings"
    dimension: 1024
    top_k: 20
    # Minimum similarity score (0.0 - 1.0)
    min_score: 0.45
    # Offline mode: skip HuggingFace API checks
    offline_mode: true

# -----------------------------------------------------------------------------
# Categories Configuration
# -----------------------------------------------------------------------------
# Define document categories for organization
categories:
  enabled: true
  labels:
    - "administration"
    - "comptabilite"
    - "juridique"
    - "technique"
    - "personnel"
    - "commercial"
    - "medical"
    - "education"
    - "autre"
  default: "autre"

# -----------------------------------------------------------------------------
# LLM Configuration (Ollama Backend)
# -----------------------------------------------------------------------------
# Configure the LLM backend for chat, RAG, and text generation.
# AItao uses Ollama to manage AI models. Models are downloaded and stored
# by Ollama itself (usually in ~/.ollama/models).
#
# To manage models via CLI:
#   ./aitao.sh models status    - View all models
#   ./aitao.sh models add       - Add a new model
#   ./aitao.sh models remove    - Remove a model
#
# See docs/MIGRATION_MODELS.md for migration from GGUF files.
llm:
  # Backend type: "ollama" (recommended, only supported backend)
  backend: "ollama"
  
  # Ollama server URL
  ollama_url: "http://localhost:11434"
  
  # Default model for chat/generation
  default_model: "llama3.1:8b"
  
  # Available models configuration
  # Each model has:
  #   - name: Ollama model identifier (e.g., "llama3.1:8b")
  #   - role: Model purpose ("chat", "code", "embedding")
  #   - required: If true, AItao won't start without this model
  #   - size_gb: Approximate download size (informational only)
  models:
    - name: "llama3.1:8b"
      role: "chat"
      required: true
      size_gb: 4.7
    - name: "qwen2.5-coder:7b"
      role: "code"
      required: false
      size_gb: 4.4
    - name: "nomic-embed-text"
      role: "embedding"
      required: false
      size_gb: 0.3
  
  # Model management at startup
  startup:
    check_models: true          # Verify models are present
    auto_pull: true             # Download missing models automatically
    pull_timeout_minutes: 30    # Timeout per model download
  
  # RAG (Retrieval-Augmented Generation) settings
  rag:
    enabled: true
    max_context_docs: 5
    max_context_tokens: 2000
  
  # Generation parameters
  generation:
    temperature: 0.7
    top_p: 0.9
    max_tokens: 2048

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
# Configure the REST API server
api:
  # Host to bind to (0.0.0.0 = all interfaces, 127.0.0.1 = localhost only)
  host: "127.0.0.1"
  
  # Port for API server
  port: 8200
  
  # Enable CORS (for web clients)
  cors_enabled: true
  
  # Allowed CORS origins (* = all, or list specific domains)
  cors_origins:
    - "*"
  
  # API rate limiting
  rate_limit:
    enabled: true
    requests_per_minute: 60
  
  # Authentication (optional)
  auth:
    enabled: false
    api_key: ""

# -----------------------------------------------------------------------------
# Resources Configuration
# -----------------------------------------------------------------------------
# Configure system resources and performance
resources:
  max_workers: 4
  batch_size: 10
  max_file_size_mb: 100
  memory_limit_mb: 2048

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
# Configure structured logging
logging:
  level: "INFO"
  max_file_size_mb: 100
  backup_count: 5
  format: "json"
  console_enabled: true
