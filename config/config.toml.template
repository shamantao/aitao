# Configuration Aitao - TEMPLATE
# Copiez ce fichier en `config.toml` et adaptez les chemins.

[system]
# Répertoire racine pour le stockage des données (VectorDB, Logs, ChatHistory)
# DOIT être un chemin absolu.
# Pour le zéro-copy, pointez vers un disque externe ou un dossier partagé.
storage_root = "/path/to/your/data_storage/.aitao"

# Chemin des logs
logs_path = "$storage_root/logs"

[models]
# Dossier contenant vos modèles GGUF téléchargés (Llama, Qwen, etc)
models_dir = "/path/to/your/models"

[indexing]
# Liste des dossiers à scanner et indexer pour le RAG
include_paths = [ 
    "/path/to/your/documents",
    "/path/to/another/folder"
]

# Modèles d'exclusion pour le scan
exclude_dirs = [ 
    "__pycache__", ".git", ".venv", "venv", "env", ".env", 
    "node_modules", ".ds_store", "dist", "build", "target", 
    "site-packages", ".idea", ".vscode" 
]
exclude_files = [ 
    ".DS_Store", "package-lock.json", "yarn.lock" 
]
exclude_extensions = [ 
    ".lock", ".log", ".tmp" 
]
